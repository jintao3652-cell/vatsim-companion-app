{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "System.Net.Http.HttpClient": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Port": "5000",
  "Bridge": {
    "EnableMdns": true,
    "ServiceName": "VATSIM Companion Bridge"
  },
  "Jwt": {
    "SecretKey": "VatsimCompanion_SecretKey_ChangeThis_InProduction_32Chars_Minimum!",
    "Issuer": "VatsimCompanionBridge",
    "Audience": "VatsimCompanionApp",
    "ExpirationMinutes": "1440"
  },
  "PushNotification": {
    "FcmServerKey": "YOUR_FCM_SERVER_KEY_HERE",
    "EnablePush": true
  }
}
